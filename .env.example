# ─── IP Query Web — 环境变量配置 ───
#
# 复制本文件为 .env 并修改：
#   cp .env.example .env
#
# 所有变量均有默认值，最小配置仅需复制即可运行

# ── 服务端口 ──
PORT=6688

# ── 监听地址（:: 双栈 / 0.0.0.0 仅IPv4 / 127.0.0.1 仅本地） ──
HOST=::

# ── 限流配置（次/分钟/IP） ──
# 普通API查询限流
RATE_LIMIT_MAX=120
# 域名解析接口限流（DNS查询较慢）
RATE_LIMIT_DNS=30
# 页面/静态资源限流
RATE_LIMIT_PAGE=120

# ── CC 防护配置（纯 Node 实现，不用系统防火墙） ──
# 单 IP 最大并发连接数
CC_MAX_CONCURRENT=20
# 突发检测窗口（毫秒）
CC_BURST_WINDOW=2000
# 窗口内最大新建连接数
CC_BURST_MAX=40
# 慢速攻击超时（毫秒），DNS 解析最长可达 20s，需留余量
CC_SLOW_TIMEOUT=30000
# 封禁时长（毫秒）
CC_BLOCK_DURATION=60000
# IP 白名单（逗号分隔），白名单内 IP 不受任何限制
# CC_WHITELIST=127.0.0.1,::1,192.168.1.0/24
# IP 黑名单（逗号分隔），永远拦截
# CC_BLACKLIST=

# ── DNS 配置 ──
# 综合查询用公共DNS，多个用逗号分隔
PUBLIC_DNS=8.8.8.8,8.8.4.4

# ── HTTPS 模式 ──
# 如需启用 HTTPS，设置 KEY 和 CERT 路径（Nginx 反向代理模式下保持注释）
# SSL_KEY=/etc/ssl/private/server.key
# SSL_CERT=/etc/ssl/certs/server.crt

# ── 数据目录 ──
# IP 数据库文件存放路径，默认 ./data
DATA_DIR=./data

# ── 日志级别 ──
LOG_LEVEL=info

# ── GitHub 镜像（国内服务器必配） ──
# 下载 IP 数据库时使用的 GitHub 加速镜像，留空直连
# 推荐: https://gh-proxy.com/  备用: https://ghproxy.net/  https://ghproxy.homeboyc.cn/
GITHUB_MIRROR=https://gh-proxy.com/

# ── CSP 域名扩展（Content-Security-Policy） ──
# 如需添加第三方统计/广告/CDN 域名，设置以下环境变量（逗号分隔）
#   CSP_EXTRA_SCRIPT:  额外允许加载 JS 的域名
#   CSP_EXTRA_IMG:     额外允许加载图片/追踪像素的域名
#   CSP_EXTRA_CONNECT: 额外允许 fetch/XHR/WebSocket 连接的域名
# 示例: 添加其他统计平台
#   CSP_EXTRA_SCRIPT=https://sdk.example.com
#   CSP_EXTRA_IMG=https://analytics.example.com
# 默认已包含: 百度统计、Google Analytics、Cloudflare、jsDelivr CDN

# ── 网站配置说明 ──
# 以下配置项通过修改静态文件完成：
#   - 统计代码: public/tracking.js（百度/Google/Cloudflare，部署时替换占位ID）
#   - 网站域名: 各HTML页面中的 <meta name="site-url" content="https://你的域名.com">
#   - ICP备案号: public/components/footer.html 底部链接
#   - SEO标题/描述/关键词: 各HTML页面中的 <title>, <meta name="description">, <meta name="keywords">
#   - ICP备案号: public/components/footer.html 底部静态链接
#   - SEO标题/描述/关键词: 各HTML页面中的 <title>, <meta name="description">, <meta name="keywords">
