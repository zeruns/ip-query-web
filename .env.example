# ─── IP Query Web — 环境变量配置 ───
#
# 复制本文件为 .env 并修改：
#   cp .env.example .env
#
# 所有变量均有默认值，最小配置仅需复制即可运行

# ── 服务端口 ──
PORT=6688

# ── 监听地址（:: 双栈 / 0.0.0.0 仅IPv4 / 127.0.0.1 仅本地） ──
HOST=::

# ── 限流配置（次/分钟/IP） ──
# 普通API查询限流
RATE_LIMIT_MAX=120
# 域名解析接口限流（DNS查询较慢）
RATE_LIMIT_DNS=30

# ── CC 防护配置（纯 Node 实现，不用系统防火墙） ──
# 单 IP 最大并发连接数
CC_MAX_CONCURRENT=20
# 突发检测窗口（毫秒）
CC_BURST_WINDOW=2000
# 窗口内最大新建连接数
CC_BURST_MAX=40
# 慢速攻击超时（毫秒），超过此时间未完成请求体接收视为慢速攻击
CC_SLOW_TIMEOUT=15000
# 封禁时长（毫秒）
CC_BLOCK_DURATION=60000
# IP 白名单（逗号分隔），白名单内 IP 不受任何限制
# CC_WHITELIST=127.0.0.1,::1,192.168.1.0/24
# IP 黑名单（逗号分隔），永远拦截
# CC_BLACKLIST=

# ── DNS 配置 ──
# 综合查询用公共DNS，多个用逗号分隔
PUBLIC_DNS=8.8.8.8,8.8.4.4

# ── HTTPS 模式 ──
# 如需启用 HTTPS，设置 KEY 和 CERT 路径（Nginx 反向代理模式下保持注释）
# SSL_KEY=/etc/ssl/private/server.key
# SSL_CERT=/etc/ssl/certs/server.crt

# ── 数据目录 ──
# IP 数据库文件存放路径，默认 ./data
DATA_DIR=./data

# ── 外部 IP 查询服务 ──
# 获取公网 IP 时使用的服务，多个用逗号分隔
PUBLIC_IP_SOURCES=https://ipinfo.io/ip,https://api.ipify.org,https://checkip.amazonaws.com

# ── 日志级别 ──
LOG_LEVEL=info

# ── GitHub 镜像（国内服务器必配） ──
# 下载 IP 数据库时使用的 GitHub 加速镜像，留空直连
# 推荐: https://gh-proxy.com/  备用: https://ghproxy.net/  https://ghproxy.homeboyc.cn/
GITHUB_MIRROR=https://gh-proxy.com/

# ── 网站配置说明 ──
# 以下配置项通过修改静态文件完成，详见各文件内 <meta> 标签：
#   - 网站域名: 各HTML页面中的 <meta name="site-url" content="https://你的域名.com">
#   - ICP备案号: public/components/footer.html 底部静态链接
#   - SEO标题/描述/关键词: 各HTML页面中的 <title>, <meta name="description">, <meta name="keywords">
